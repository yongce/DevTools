<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/nav_header_height"
    android:background="@drawable/side_nav_bar"
    android:gravity="bottom"
    android:orientation="vertical"
    android:paddingBottom="?attr/ycdevActivityVerticalMargin"
    android:paddingLeft="?attr/ycdevActivityHorizontalMargin"
    android:paddingRight="?attr/ycdevActivityHorizontalMargin"
    android:paddingTop="?attr/ycdevActivityVerticalMargin">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:contentDescription="@string/app_name"
        android:padding="3dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_launcher_legacy" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="@dimen/nav_header_vertical_spacing"
        android:text="@string/developer_name"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/colorOnPrimaryContainer"
        android:text="@string/developer_home_page_url" />

</LinearLayout>
